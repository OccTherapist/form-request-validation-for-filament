{
    "name": "occ-therapist/form-request-validation-for-filament",
    "description": "Use Laravel Form Request validation rules inside Filament schemas.",
    "keywords": [
        "filament",
        "laravel",
        "form-request",
        "validation"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "occTherapist"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0|^5.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/validation": "^11.0|^12.0|^13.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "OccTherapist\\FormRequestValidationForFilament\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OccTherapist\\FormRequestValidationForFilament\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "OccTherapist\\FormRequestValidationForFilament\\FormRequestValidationServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "pest"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
